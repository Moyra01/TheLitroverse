<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>To-Do List App</title>
  <style>
    body {
      background: #f6f8fa;
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 0;
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: flex-start;
    }
    .todo-container {
      background: #fff;
      margin-top: 50px;
      padding: 30px 40px;
      border-radius: 8px;
      box-shadow: 0 6px 32px rgba(24,35,56,.14);
      width: 350px;
    }
    h2 {
      margin-top: 0;
      text-align: center;
      color: #2980b9;
    }
    .input-row {
      display: flex;
      margin-bottom: 20px;
    }
    input[type="text"] {
      flex: 1;
      padding: 8px;
      font-size: 16px;
      border: 1px solid #e0e0e0;
      border-radius: 4px 0 0 4px;
      outline: none;
    }
    button {
      background: #2980b9;
      color: #fff;
      border: none;
      padding: 8px 14px;
      border-radius: 0 4px 4px 0;
      cursor: pointer;
      font-size: 16px;
      transition: background 0.2s;
    }
    button:hover {
      background: #1669a1;
    }
    ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    li {
      padding: 10px 0;
      border-bottom: 1px solid #eee;
      display: flex;
      align-items: center;
      transition: background 0.18s;
    }
    li:last-child {
      border-bottom: none;
    }
    .task {
      flex: 1;
      cursor: pointer;
    }
    .task.completed {
      text-decoration: line-through;
      color: #aaa;
      opacity: 0.65;
    }
    .remove {
      background: #d32f2f;
      color: #fff;
      border: none;
      border-radius: 15px;
      padding: 4px 10px;
      margin-left: 14px;
      cursor: pointer;
      font-size: 14px;
      transition: background 0.2s;
    }
    .remove:hover {
      background: #a02626;
    }
    .empty {
      text-align: center;
      color: #888;
      margin-top: 15px;
    }
  </style>
</head>
<body>
  <div class="todo-container">
    <h2>To-Do List</h2>
    <div class="input-row">
      <input type="text" id="taskInput" placeholder="Add new task...">
      <button onclick="addTask()">Add</button>
    </div>
    <ul id="todoList"></ul>
    <div class="empty" id="emptyMsg">No tasks yet. Add your first one!</div>
  </div>
  <script>
    // Load tasks from localStorage or empty array
    let tasks = JSON.parse(localStorage.getItem('tasks') || "[]");

    function saveTasks() {
      localStorage.setItem('tasks', JSON.stringify(tasks));
    }

    function renderList() {
      const list = document.getElementById('todoList');
      const empty = document.getElementById('emptyMsg');
      list.innerHTML = '';
      if (tasks.length === 0) {
        empty.style.display = '';
        return;
      }
      empty.style.display = 'none';
      tasks.forEach((t, idx) => {
        const li = document.createElement('li');
        const task = document.createElement('span');
        task.className = 'task' + (t.completed ? ' completed' : '');
        task.textContent = t.text;
        task.onclick = () => toggleComplete(idx);
        li.appendChild(task);

        const removeBtn = document.createElement('button');
        removeBtn.className = 'remove';
        removeBtn.textContent = 'Remove';
        removeBtn.onclick = () => removeTask(idx);
        li.appendChild(removeBtn);

        list.appendChild(li);
      });
    }

    function addTask() {
      const input = document.getElementById('taskInput');
      const text = input.value.trim();
      if (!text) return;
      tasks.push({text, completed: false});
      input.value = '';
      saveTasks();
      renderList();
    }

    function removeTask(i) {
      tasks.splice(i, 1);
      saveTasks();
      renderList();
    }

    function toggleComplete(i) {
      tasks[i].completed = !tasks[i].completed;
      saveTasks();
      renderList();
    }

    // Enter-press triggers add
    document.getElementById('taskInput').addEventListener('keydown', function(e){
      if (e.key === 'Enter') addTask();
    });

    // Initial render
    renderList();
  </script>
</body>
</html>
